# Supabase Configuration
# Get these values from: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api

# Your Supabase project ID
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Your Supabase project URL
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Your Supabase anonymous (publishable) key
# This is safe to expose in client-side code
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Google OAuth Configuration
# Get this from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_OAUTH_CLIENT_ID="your-google-oauth-client-id"

# Important Notes:
# - Copy this file to .env and replace the placeholder values
# - Never commit your .env file to version control
# - The .env file is already in .gitignore
# - All variables prefixed with VITE_ are accessible in the browser
